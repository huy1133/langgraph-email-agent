# Copy thành file .env và điền giá trị (không commit .env)

# Bắt buộc: API key (OpenAI hoặc provider tương thích OpenAI API)
LLM_API_KEY=

# Tuỳ chọn: endpoint gốc, ví dụ proxy hoặc dịch vụ tương thích OpenAI
# Để trống = dùng mặc định của SDK (OpenAI chính thức)
# BASE_URL=https://api.openai.com/v1

# Model embedding (ingest / vector search)
LLM_EMBEDDING_MODEL=text-embedding-3-small

# Model chat — dùng ở giai đoạn agent / FastAPI sau; script ingest hiện không gọi chat
LLM_CHAT_MODEL=gpt-4o-mini
